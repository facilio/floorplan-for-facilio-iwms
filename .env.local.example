# Copy to .env.local for local development. Never commit .env.local.
#
# This build has TWO modes only: local dev (data from the editable src/data/*.json seed +
# localStorage) and connected-app (real Facilio V3 API). There is no vibe-db or connector tier.

# Local dev with the built-in JSON data: leave everything below as-is (all blank/false). The app
# serves src/data/*.json and persists this session's edits to localStorage.

# ---- Optional: dev against a real Facilio org via a bearer token ----
# Set VITE_DEV_MODE=true and fill both vars to fetch a real org's data during `npm run dev`.
# The token is sent as a Bearer header to VITE_FACILIO_API_BASE_URL (a Facilio org's REST API,
# including the /api prefix — e.g. https://your-org.facilio.com/api). Requests route through the
# vite dev-server proxy ('/fapi' → base URL, see vite.config.ts) to dodge CORS. Tokens are often
# short-lived; regenerate if calls start 401ing. Leave VITE_DEV_MODE=false to use JSON only.
VITE_DEV_MODE=false
VITE_FACILIO_API_BASE_URL=
VITE_FACILIO_TOKEN=

# ---- Connected-app mode ----
# Set true ONLY for builds served INSIDE a Facilio org (connected app tab/iframe). The V3 APIs are
# then called same-origin with the user's session cookies — no token — and this OVERRIDES dev mode:
# the real API renders the data, and the local JSON tier is the fallback only. Leave false for dev.
VITE_IS_CONNECTED_APP=false
